{
  "$schema": "https://json.schemastore.org/template",
  "author": "Mofajjal Rasul",
  "name": "DevInsightForge Web API Template",
  "description": "Template for a DevInsightForge Web API project with Clean Architecture, MediatR, EF Core, and JWT authentication.",
  "identity": "DevInsightForge.Templates.Api",
  "groupIdentity": "DevInsightForge.Templates.Api",
  "version": "4.0.0",
  "shortName": "devforgeapi",
  "defaultName": "DevInsightForge",
  "precedence": 100,
  "classifications": [
    "Web",
    "API",
    "Clean Architecture",
    "DDD",
    "MediatR",
    "EF Core",
    "JWT"
  ],
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "DevInsightForge",
  "preferNameDirectory": true,
  "primaryOutputs": [
    {
      "path": "DevInsightForge.sln"
    }
  ],
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/[Bb]in/**",
            "**/[Oo]bj/**",
            ".vs/**"
          ]
        }
      ]
    }
  ],
  "constraints": {
    "minimumSdk": {
      "type": "host",
      "args": [
        {
          "hostname": "dotnetcli",
          "version": "[10.0.100,)"
        }
      ]
    }
  },
  "guids": []
}
