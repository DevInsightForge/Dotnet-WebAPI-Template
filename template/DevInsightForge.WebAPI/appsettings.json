{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DatabaseServer": ""
  },
  "JwtConfiguration": {
    "SecretKey": "",
    "ValidateIssuer": false,
    "ValidIssuer": "",
    "ValidateAudience": false,
    "ValidAudience": "",
    "AccessTokenExpirationInMinutes": ""
  },
  "EmailConfiguration": {
    "EmailFrom": "",
    "SmtpHost": "",
    "SmtpPort": 0,
    "SmtpSsl": false,
    "SmtpUser": "",
    "SmtpPassword": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Error",
      "Override": {
        "Microsoft": "Error",
        "System": "Error"
      }
    },
    "WriteTo": [
      "Console"
    ],
    "Enrich": [
      "FromLogContext",
      "WithThreadId",
      "WithMachineName"
    ]
  }
}
