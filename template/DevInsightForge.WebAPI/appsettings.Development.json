{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DatabaseServer": "Host=localhost;Database=TemplateDB;Username=postgres;Password=postgres;"
  },
  "JwtConfigurations": {
    "SecretKey": "Default_Super_Secret_256_Bits_Signing_Key",
    "ValidateIssuer": false,
    "ValidIssuer": "https://localhost:44370/",
    "ValidateAudience": false,
    "ValidAudience": "https://localhost:44370/",
    "AccessTokenExpirationInMinutes": "100"
  },
  "EmailSetting": {
    "EmailFrom": "no-reply@devinsightforge.local",
    "SmtpHost": "localhost",
    "SmtpPort": 2525,
    "SmtpSSL": false,
    "SmtpUser": "",
    "SmtpPassword": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithMachineName" ]
  }
}
